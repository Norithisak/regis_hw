<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'DM Sans', sans-serif; }
    h1   { font-family: 'DM Serif Display', serif; }
  </style>
</head>
<body class="min-h-screen bg-amber-50 flex items-center justify-center p-6">

  <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 border border-amber-100">

    <div class="mb-8 text-center">
      <span class="inline-block bg-amber-100 text-amber-700 text-xs font-semibold tracking-widest uppercase px-3 py-1 rounded-full mb-3">Enrollment</span>
      <h1 class="text-3xl text-stone-800">Create Your Account</h1>
      <p class="text-stone-500 text-sm mt-1">Fill in the details below to get started.</p>
    </div>

    <form action="/register" method="POST" enctype="multipart/form-data" class="space-y-5">

      <div>
        <label for="name" class="block text-sm font-medium text-stone-700 mb-1">Full Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Jane Doe"
          class="w-full px-4 py-2.5 rounded-lg border border-stone-200 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-transparent text-stone-800 placeholder-stone-300 transition"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-stone-700 mb-1">Email Address</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="jane@example.com"
          class="w-full px-4 py-2.5 rounded-lg border border-stone-200 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-transparent text-stone-800 placeholder-stone-300 transition"
        />
      </div>

      <div>
        <label for="course" class="block text-sm font-medium text-stone-700 mb-1">Course Track</label>
        <select
          id="course"
          name="course"
          required
          class="w-full px-4 py-2.5 rounded-lg border border-stone-200 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-transparent text-stone-800 bg-white transition"
        >
          <option value="" disabled selected>Select a track…</option>
          <option value="Web Dev">Web Development</option>
          <option value="Data Science">Data Science</option>
          <option value="UX Design">UX Design</option>
        </select>
      </div>

      <div>
        <label for="profilePicture" class="block text-sm font-medium text-stone-700 mb-1">Profile Picture</label>
        <input
          type="file"
          id="profilePicture"
          name="profilePicture"
          accept=".jpg,.jpeg,.png"
          required
          class="w-full text-sm text-stone-500
                 file:mr-4 file:py-2 file:px-4
                 file:rounded-lg file:border-0
                 file:text-sm file:font-semibold
                 file:bg-amber-100 file:text-amber-700
                 hover:file:bg-amber-200 cursor-pointer transition"
        />
        <p class="text-xs text-stone-400 mt-1">Accepted formats: .jpg, .jpeg, .png</p>
      </div>

      <button
        type="submit"
        class="w-full bg-amber-500 hover:bg-amber-600 text-white font-semibold py-3 rounded-lg transition-colors duration-200 mt-2"
      >
        Register →
      </button>

    </form>
  </div>

</body>
</html>
