<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome, {{name}}!</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'DM Sans', sans-serif; }
    h1, h2 { font-family: 'DM Serif Display', serif; }
  </style>
</head>
<body class="min-h-screen bg-amber-50 flex items-center justify-center p-6">

  <div class="w-full max-w-sm bg-white rounded-2xl shadow-lg border border-amber-100 overflow-hidden">

    <div class="bg-amber-500 px-8 pt-10 pb-16 text-center relative">
      <span class="inline-block bg-amber-400 text-white text-xs font-semibold tracking-widest uppercase px-3 py-1 rounded-full mb-3">Registration Complete</span>
      <h1 class="text-3xl text-white">Welcome, {{name}}!</h1>
      <p class="text-amber-100 text-sm mt-1">You're officially enrolled.</p>
    </div>

    <div class="flex justify-center -mt-12 px-8">
      <img
        src="{{imagePath}}"
        alt="Profile picture of {{name}}"
        class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-md"
      />
    </div>

    <div class="px-8 py-6 space-y-4">

      <div class="flex items-center gap-3 bg-amber-50 rounded-xl px-4 py-3">
        <span class="text-amber-500 text-lg">✉</span>
        <div>
          <p class="text-xs text-stone-400 font-medium uppercase tracking-wide">Email</p>
          <p class="text-stone-700 font-semibold text-sm">{{email}}</p>
        </div>
      </div>

      <div class="flex items-center gap-3 bg-amber-50 rounded-xl px-4 py-3">
        <span class="text-amber-500 text-lg">📚</span>
        <div>
          <p class="text-xs text-stone-400 font-medium uppercase tracking-wide">Course Track</p>
          <p class="text-stone-700 font-semibold text-sm">{{course}}</p>
        </div>
      </div>

      <a
        href="/register"
        class="block text-center w-full bg-stone-800 hover:bg-stone-900 text-white font-semibold py-3 rounded-lg transition-colors duration-200 mt-2"
      >
        ← Register Another
      </a>

    </div>
  </div>

</body>
</html>
